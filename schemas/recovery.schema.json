{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Worker Recovery Configuration",
  "type": "object",
  "properties": {
    "stall_timeout_seconds": { "type": "integer", "minimum": 10, "default": 120 },
    "max_retries": { "type": "integer", "minimum": 0, "default": 3 },
    "checkpoint_enabled": { "type": "boolean", "default": true },
    "stall_no_diff_minutes": { "type": "integer", "minimum": 1, "default": 10 },
    "stall_no_test_minutes": { "type": "integer", "minimum": 1, "default": 15 },
    "auto_stop_stalled": { "type": "boolean", "default": false },
    "compaction_interval_minutes": { "type": "integer", "minimum": 1, "default": 15 },
    "max_context_tokens_estimate": { "type": "integer", "minimum": 1000, "default": 80000 },
    "auto_compact": { "type": "boolean", "default": true }
  }
}
